NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=
# Set to 1 to pause outbound Vercel Web Analytics collection while keeping
# the app-owned Supabase analytics store active. Redeploy after changing.
NEXT_PUBLIC_VERCEL_ANALYTICS_PAUSED=
SUPABASE_SERVICE_ROLE_KEY=
SUPABASE_STORAGE_BUCKET=datasets
GOOGLE_SHEETS_OAUTH_CLIENT_ID=
GOOGLE_SHEETS_OAUTH_CLIENT_SECRET=

# Use a Supabase Postgres connection string. The Supabase pooler URL is preferred
# for deployed serverless functions; include sslmode=require when Supabase provides it.
DATABASE_URL=

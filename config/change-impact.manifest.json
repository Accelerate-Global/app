{
  "changeImpactDomains": [
    {
      "id": "planner-policy",
      "label": "Planner policy and agent workflow",
      "patterns": [
        "AGENTS.md",
        ".github/actions/**",
        "config/**/*.ts",
        "scripts/check-workflow-bootstrap.mjs",
        "scripts/verify-change.ts",
        "scripts/verify-change-run.ts",
        "scripts/check-test-delta.ts",
        "scripts/lib/test-impact.ts",
        "scripts/lib/verify-change-report.ts",
        "scripts/lib/verify-change.ts"
      ],
      "requiredCommands": ["typecheck", "verify:test-delta"],
      "recommendedCommands": ["verify:app"],
      "manualSteps": [],
      "contractRequirements": []
    },
    {
      "id": "app-runtime",
      "label": "Application and script runtime",
      "patterns": [
        "package.json",
        "scripts/**/*.ts",
        "src/app/**/*.ts",
        "src/app/**/*.tsx",
        "src/components/**/*.ts",
        "src/components/**/*.tsx",
        "src/db/**/*.ts",
        "src/db/**/*.tsx",
        "src/lib/**/*.ts",
        "src/lib/**/*.tsx",
        "tests/**/*.ts",
        "tests/**/*.tsx"
      ],
      "requiredCommands": ["typecheck", "verify:test-delta", "verify:app"],
      "recommendedCommands": [],
      "manualSteps": [],
      "contractRequirements": []
    },
    {
      "id": "ui-pages",
      "label": "Smoke-tracked App Router pages",
      "patterns": ["src/app/**/page.tsx"],
      "requiredCommands": ["smoke:check", "test:ui:smoke:targeted"],
      "recommendedCommands": [],
      "manualSteps": [],
      "contractRequirements": [
        "route-registry-entry",
        "page-marker",
        "page-ready-marker",
        "smoke-surface-literals"
      ]
    },
    {
      "id": "ui-primitives",
      "label": "Shared UI primitives",
      "patterns": ["src/components/ui/**/*.ts", "src/components/ui/**/*.tsx"],
      "requiredCommands": ["smoke:check", "test:ui:smoke:targeted"],
      "recommendedCommands": [],
      "manualSteps": [],
      "contractRequirements": ["shared-ui-fixture", "smoke-surface-literals"]
    },
    {
      "id": "ui-smoke-harness",
      "label": "UI smoke harness and fixtures",
      "patterns": [
        ".github/workflows/ui-smoke.yml",
        "playwright.smoke.config.ts",
        "scripts/check-ui-smoke-env.ts",
        "scripts/run-ui-smoke.ts",
        "scripts/smoke-bootstrap.ts",
        "tests/ui/global.setup.ts",
        "tests/ui/support/**/*.ts",
        "tests/ui/support/**/*.tsx"
      ],
      "requiredCommands": ["smoke:check", "test:ui:smoke"],
      "recommendedCommands": [],
      "manualSteps": [],
      "contractRequirements": [
        "route-registry-entry",
        "page-marker",
        "page-ready-marker",
        "shared-ui-fixture",
        "smoke-surface-literals"
      ]
    },
    {
      "id": "ui-smoke-contract",
      "label": "UI smoke contract validation",
      "patterns": ["scripts/check-ui-smoke.ts"],
      "requiredCommands": ["smoke:check"],
      "recommendedCommands": [],
      "manualSteps": [],
      "contractRequirements": []
    },
    {
      "id": "ui-smoke-specs",
      "label": "UI smoke route and journey specs",
      "patterns": [
        "tests/ui/00-route-sweep.spec.ts",
        "tests/ui/10-journeys.spec.ts",
        "tests/ui/route-registry.ts"
      ],
      "requiredCommands": ["smoke:check", "test:ui:smoke:targeted"],
      "recommendedCommands": [],
      "manualSteps": [],
      "contractRequirements": []
    },
    {
      "id": "database-security",
      "label": "Database access and security",
      "patterns": [
        ".github/workflows/database-security.yml",
        "scripts/check-public-rls.mjs",
        "scripts/run-remote-db-tests.mjs",
        "src/db/**",
        "src/lib/auth.ts",
        "src/lib/field-definitions.ts",
        "src/lib/field-sources.ts",
        "src/lib/signup-allowlist.ts",
        "src/lib/supabase/**",
        "src/lib/user-management.ts",
        "src/lib/workspace-role.ts",
        "src/lib/api-connections.ts",
        "src/app/api/admin/users/**",
        "src/app/api/admin/api-connections/**",
        "supabase/**"
      ],
      "requiredCommands": ["db:security"],
      "recommendedCommands": [],
      "manualSteps": [],
      "contractRequirements": []
    },
    {
      "id": "database-migrations",
      "label": "Tracked Supabase migrations",
      "patterns": ["supabase/migrations/**"],
      "requiredCommands": ["db:security", "db:check-migration-drift"],
      "recommendedCommands": [],
      "manualSteps": ["db:push:remote"],
      "contractRequirements": []
    }
  ],
  "uiSmokeTargetRules": [
    {
      "id": "ui-smoke-harness-full",
      "label": "Smoke harness and browser runner changes",
      "patterns": [
        ".github/workflows/ui-smoke.yml",
        "playwright.smoke.config.ts",
        "scripts/check-ui-smoke-env.ts",
        "scripts/run-ui-smoke.ts",
        "scripts/smoke-bootstrap.ts",
        "tests/ui/global.setup.ts",
        "tests/ui/support/bootstrap.ts",
        "tests/ui/support/project-context.ts",
        "tests/ui/support/smoke-data.ts",
        "tests/ui/support/smoke-helpers.ts"
      ],
      "forceFullSuite": true
    },
    {
      "id": "route-sweep-spec",
      "label": "Route sweep smoke spec",
      "patterns": [
        "tests/ui/00-route-sweep.spec.ts",
        "tests/ui/route-registry.ts"
      ],
      "testPaths": ["tests/ui/00-route-sweep.spec.ts"],
      "bootstrapScope": "full"
    },
    {
      "id": "journeys-spec",
      "label": "Journey smoke spec",
      "patterns": ["tests/ui/10-journeys.spec.ts"],
      "testPaths": ["tests/ui/10-journeys.spec.ts"],
      "bootstrapScope": "full"
    },
    {
      "id": "auth-entry-routes",
      "label": "Anonymous auth entry routes",
      "patterns": [
        "src/app/page.tsx",
        "src/app/sign-in/page.tsx",
        "src/app/sign-up/page.tsx",
        "src/app/forgot-password/page.tsx",
        "src/app/reset-password/page.tsx",
        "src/app/auth/confirm/**",
        "src/components/auth/auth-form.tsx",
        "src/components/auth/forgot-password-form.tsx",
        "src/components/auth/reset-password-form.tsx"
      ],
      "routeIds": [
        "home-sign-in-anonymous",
        "sign-up-anonymous",
        "forgot-password-anonymous",
        "reset-password-anonymous",
        "sign-in-redirect-anonymous"
      ],
      "journeyTitles": [
        "allowlisted user can sign up",
        "blocked user cannot sign up",
        "forgot-password request succeeds",
        "recovery link lands on reset-password",
        "password reset completes"
      ],
      "projectNames": ["desktop-anonymous"],
      "bootstrapScope": "auth"
    },
    {
      "id": "smoke-fixtures",
      "label": "Shared UI fixtures and fixture gallery",
      "patterns": [
        "src/app/%5F_smoke/components/**",
        "src/components/ui/**/*.ts",
        "src/components/ui/**/*.tsx"
      ],
      "routeIds": ["smoke-components-anonymous"],
      "projectNames": ["desktop-anonymous", "mobile-anonymous"],
      "bootstrapScope": "auth"
    },
    {
      "id": "dashboard-shell",
      "label": "Authenticated dashboard shell",
      "patterns": [
        "src/components/layout/site-header.tsx",
        "src/components/auth/account-control.tsx",
        "src/components/dashboard/dashboard-client.tsx",
        "src/lib/auth.ts",
        "src/lib/supabase/**"
      ],
      "routeIds": ["dashboard-pro", "dashboard-basic", "dashboard-admin"],
      "journeyTitles": ["signed-in user can sign out"],
      "projectNames": ["desktop-anonymous", "desktop-pro", "desktop-basic", "desktop-admin"],
      "bootstrapScope": "full"
    },
    {
      "id": "datasets-index",
      "label": "Datasets index and dashboard landing",
      "patterns": [
        "src/app/dashboard/page.tsx",
        "src/app/dashboard/datasets/page.tsx",
        "src/components/dashboard/datasets-grid.tsx"
      ],
      "routeIds": [
        "dashboard-pro",
        "dashboard-basic",
        "dashboard-admin",
        "datasets-index-pro",
        "datasets-index-basic",
        "datasets-index-admin"
      ],
      "projectNames": ["desktop-pro", "desktop-basic", "desktop-admin"],
      "bootstrapScope": "datasets"
    },
    {
      "id": "dataset-data",
      "label": "Dataset data access and API flows",
      "patterns": [
        "src/app/api/datasets/**",
        "src/lib/dataset-*.ts"
      ],
      "routeIds": [
        "dashboard-pro",
        "dashboard-basic",
        "dashboard-admin",
        "datasets-index-pro",
        "datasets-index-basic",
        "datasets-index-admin",
        "dataset-detail-pro",
        "dataset-detail-basic",
        "dataset-detail-admin",
        "dataset-edit-pro-redirect",
        "dataset-edit-basic-redirect",
        "dataset-edit-admin"
      ],
      "projectNames": ["desktop-pro", "desktop-basic", "desktop-admin"],
      "bootstrapScope": "datasets"
    },
    {
      "id": "dataset-detail",
      "label": "Dataset detail tables and presets",
      "patterns": [
        "src/app/dashboard/datasets/[datasetId]/page.tsx",
        "src/components/dashboard/dataset-detail-client.tsx",
        "src/components/dashboard/dataset-open-preset-sheet.tsx",
        "src/components/dashboard/dataset-table-action-bar.tsx",
        "src/components/dashboard/dataset-table.tsx",
        "src/components/dashboard/dataset-tag-list.tsx",
        "src/components/dashboard/dataset-view-switch-grid.tsx",
        "src/components/dashboard/use-dataset-table-state.tsx",
        "src/lib/saved-dataset-tables.ts"
      ],
      "routeIds": ["dataset-detail-pro", "dataset-detail-basic", "dataset-detail-admin"],
      "journeyTitles": ["basic user can filter and download without saving"],
      "projectNames": ["desktop-pro", "desktop-basic", "desktop-admin"],
      "bootstrapScope": "datasets"
    },
    {
      "id": "dataset-edit",
      "label": "Dataset edit flows",
      "patterns": [
        "src/app/dashboard/datasets/[datasetId]/edit/**",
        "src/components/dashboard/dataset-edit-page-client.tsx"
      ],
      "routeIds": ["dataset-edit-pro-redirect", "dataset-edit-basic-redirect", "dataset-edit-admin"],
      "journeyTitles": ["admin can edit dataset details"],
      "projectNames": ["desktop-pro", "desktop-basic", "desktop-admin"],
      "bootstrapScope": "datasets"
    },
    {
      "id": "upload",
      "label": "Upload route and dataset replacement flow",
      "patterns": [
        "src/app/dashboard/upload/**",
        "src/components/dashboard/dataset-upload-client.tsx",
        "src/app/api/blob/**",
        "src/app/api/datasets/[datasetId]/replace/**"
      ],
      "routeIds": ["upload-pro-redirect", "upload-basic-redirect", "upload-admin"],
      "journeyTitles": ["admin can replace a dataset through the real upload flow"],
      "projectNames": ["desktop-pro", "desktop-basic", "desktop-admin"],
      "bootstrapScope": "datasets"
    },
    {
      "id": "field-definitions",
      "label": "Field Definitions routes and edit flow",
      "patterns": [
        "src/app/dashboard/field-definitions/**",
        "src/components/dashboard/field-definition-*.tsx",
        "src/components/dashboard/field-definitions-client.tsx",
        "src/components/dashboard/field-source-tag-list.tsx",
        "src/lib/field-definition-*.ts",
        "src/lib/field-definitions.ts",
        "src/app/api/field-definitions/**"
      ],
      "routeIds": ["field-definitions-pro", "field-definitions-basic", "field-definitions-admin"],
      "journeyTitles": ["admin can edit a field definition"],
      "projectNames": ["desktop-pro", "desktop-basic", "desktop-admin"],
      "bootstrapScope": "admin-config"
    },
    {
      "id": "field-sources",
      "label": "Field Sources routes and source mapping flow",
      "patterns": [
        "src/app/dashboard/field-sources/**",
        "src/components/dashboard/field-sources-client.tsx",
        "src/components/dashboard/field-source-tag-list.tsx",
        "src/lib/field-sources.ts",
        "src/app/api/field-sources/**",
        "src/app/api/field-source-types/**"
      ],
      "routeIds": ["field-sources-pro-redirect", "field-sources-basic-redirect", "field-sources-admin"],
      "journeyTitles": ["admin can review field source mappings"],
      "projectNames": ["desktop-pro", "desktop-basic", "desktop-admin"],
      "bootstrapScope": "admin-config"
    },
    {
      "id": "api-connections",
      "label": "API Connections route and admin import flow",
      "patterns": [
        "src/app/dashboard/api-connections/**",
        "src/components/dashboard/api-connections-client.tsx",
        "src/lib/api-connections.ts",
        "src/app/api/admin/api-connections/**"
      ],
      "routeIds": [
        "api-connections-pro-redirect",
        "api-connections-basic-redirect",
        "api-connections-admin"
      ],
      "projectNames": ["desktop-pro", "desktop-basic", "desktop-admin"],
      "bootstrapScope": "admin-config"
    },
    {
      "id": "profile",
      "label": "Profile and account settings",
      "patterns": [
        "src/app/dashboard/profile/**",
        "src/components/auth/account-profile-form.tsx",
        "src/app/api/account/**"
      ],
      "routeIds": ["profile-pro", "profile-basic", "profile-admin"],
      "journeyTitles": [
        "signed-in user can sign out",
        "disabled user cannot sign back in",
        "basic profile is read-only"
      ],
      "projectNames": ["desktop-anonymous", "desktop-pro", "desktop-basic", "desktop-admin"],
      "bootstrapScope": "auth"
    },
    {
      "id": "user-management",
      "label": "User Management route and admin account controls",
      "patterns": [
        "src/app/dashboard/user-management/**",
        "src/components/dashboard/user-management-client.tsx",
        "src/components/auth/account-control.tsx",
        "src/lib/user-management.ts",
        "src/lib/workspace-role.ts",
        "src/app/api/admin/users/**",
        "src/app/api/account/disable/**"
      ],
      "routeIds": ["user-management-pro-redirect", "user-management-basic-redirect", "user-management-admin"],
      "projectNames": ["desktop-pro", "desktop-basic", "desktop-admin"],
      "bootstrapScope": "admin-config"
    }
  ],
  "ci": {
    "preinstallWorkflows": {
      "appQualityPatterns": [
        ".github/actions/**",
        ".github/workflows/**",
        "package.json",
        "pnpm-lock.yaml",
        "config/**/*.ts",
        "scripts/check-workflow-bootstrap.mjs",
        "scripts/**/*.ts",
        "src/**/*.ts",
        "src/**/*.tsx",
        "tests/**/*.ts",
        "tests/**/*.tsx",
        "drizzle.config.ts",
        "eslint.config.mjs",
        "next.config.ts",
        "playwright.smoke.config.ts",
        "tsconfig.json",
        "vitest.config.ts"
      ],
      "uiSmokePatterns": [
        ".github/workflows/ui-smoke.yml",
        "playwright.smoke.config.ts",
        "scripts/check-ui-smoke.ts",
        "scripts/check-ui-smoke-env.ts",
        "scripts/run-ui-smoke.ts",
        "scripts/smoke-bootstrap.ts",
        "tests/ui/**/*.ts",
        "tests/ui/**/*.tsx",
        "src/app/**/page.tsx",
        "src/components/ui/**/*.ts",
        "src/components/ui/**/*.tsx",
        "src/app/auth/confirm/**",
        "src/app/dashboard/**",
        "src/app/page.tsx",
        "src/app/forgot-password/page.tsx",
        "src/app/reset-password/page.tsx",
        "src/app/sign-in/page.tsx",
        "src/app/sign-up/page.tsx",
        "src/components/auth/**/*.tsx",
        "src/components/layout/site-header.tsx",
        "src/components/dashboard/**/*.ts",
        "src/components/dashboard/**/*.tsx",
        "src/lib/auth.ts",
        "src/lib/dataset-*.ts",
        "src/lib/filter-settings.ts",
        "src/lib/field-definition-*.ts",
        "src/lib/field-definitions.ts",
        "src/lib/field-sources.ts",
        "src/lib/saved-dataset-tables.ts",
        "src/lib/supabase/**",
        "src/lib/user-management.ts",
        "src/lib/workspace-role.ts",
        "src/app/api/account/**",
        "src/app/api/admin/users/**",
        "src/app/api/blob/**",
        "src/app/api/datasets/**",
        "src/app/api/field-definitions/**",
        "src/app/api/field-source-types/**",
        "src/app/api/field-sources/**"
      ],
      "databaseSecurityPatterns": [
        ".github/workflows/database-security.yml",
        "scripts/check-public-rls.mjs",
        "scripts/run-remote-db-tests.mjs",
        "src/db/**",
        "src/lib/auth.ts",
        "src/lib/field-definitions.ts",
        "src/lib/field-sources.ts",
        "src/lib/signup-allowlist.ts",
        "src/lib/supabase/**",
        "src/lib/user-management.ts",
        "src/lib/workspace-role.ts",
        "src/app/api/admin/users/**",
        "supabase/**"
      ],
      "dependencyAuditPatterns": ["package.json", "pnpm-lock.yaml"]
    },
    "appQualityTasks": {
      "lintPatterns": [
        ".github/actions/**",
        "package.json",
        "pnpm-lock.yaml",
        "config/**/*.ts",
        "scripts/check-workflow-bootstrap.mjs",
        "scripts/**/*.ts",
        "src/**/*.ts",
        "src/**/*.tsx",
        "tests/**/*.ts",
        "tests/**/*.tsx",
        "drizzle.config.ts",
        "eslint.config.mjs",
        "next.config.ts",
        "playwright.smoke.config.ts",
        "tsconfig.json",
        "vitest.config.ts"
      ],
      "testPatterns": [
        ".github/actions/**",
        "package.json",
        "pnpm-lock.yaml",
        "config/**/*.ts",
        "scripts/check-workflow-bootstrap.mjs",
        "scripts/**/*.ts",
        "src/**/*.ts",
        "src/**/*.tsx",
        "tests/**/*.ts",
        "tests/**/*.tsx",
        "drizzle.config.ts",
        "eslint.config.mjs",
        "next.config.ts",
        "playwright.smoke.config.ts",
        "tsconfig.json",
        "vitest.config.ts"
      ],
      "buildPatterns": [
        "package.json",
        "pnpm-lock.yaml",
        "src/**/*.ts",
        "src/**/*.tsx",
        "drizzle.config.ts",
        "next.config.ts",
        "tsconfig.json"
      ]
    }
  }
}

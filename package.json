{
  "name": "online",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "eslint",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:ui:smoke": "node --import tsx scripts/run-ui-smoke.ts",
    "test:ui:smoke:headed": "node --import tsx scripts/run-ui-smoke.ts --headed",
    "test:ui:smoke:targeted": "node --import tsx scripts/run-ui-smoke.ts --targeted",
    "smoke:bootstrap": "node --import tsx scripts/smoke-bootstrap.ts",
    "smoke:check": "node --import tsx scripts/check-ui-smoke.ts",
    "smoke:preflight": "node --import tsx scripts/check-ui-smoke-env.ts",
    "verify:test-delta": "node --import tsx scripts/check-test-delta.ts",
    "verify:change": "node --import tsx scripts/verify-change.ts",
    "verify:change:run": "node --import tsx scripts/verify-change-run.ts",
    "verify:ship:local": "node --import tsx scripts/verify-ship-local.ts",
    "verify:app": "node --import tsx scripts/verify-app.ts",
    "verify:release": "node --import tsx scripts/verify-ship-local.ts --deprecated-alias",
    "db:generate": "drizzle-kit generate",
    "db:start": "supabase start",
    "db:push": "supabase db push --local && pnpm run field-sources:seed:local",
    "db:push:remote": "node --import tsx scripts/push-remote-migrations.ts",
    "db:reset": "supabase db reset --local --no-seed --yes && pnpm run field-sources:seed:local",
    "db:check-rls": "dotenv -e .env.local -- node scripts/check-public-rls.mjs",
    "db:check-rls:local": "DATABASE_URL=postgresql://postgres:postgres@127.0.0.1:54322/postgres node scripts/check-public-rls.mjs",
    "db:lint": "supabase db lint --local --level error",
    "db:lint:remote": "supabase db lint --linked --level error",
    "db:test": "supabase test db",
    "db:test:remote": "dotenv -e .env.local -- node scripts/run-remote-db-tests.mjs",
    "db:security:started": "pnpm db:check-rls:local && pnpm db:lint && pnpm db:test",
    "db:security": "supabase start && supabase db reset --local --no-seed --yes && pnpm run db:security:started",
    "db:security:remote": "pnpm db:check-rls && pnpm db:lint:remote && pnpm db:test:remote",
    "db:check-migration-drift": "node --import tsx scripts/check-linked-migration-drift.ts",
    "field-sources:seed": "node --import tsx scripts/seed-field-sources.ts",
    "field-sources:seed:local": "DATABASE_URL=postgresql://postgres:postgres@127.0.0.1:54322/postgres pnpm run field-sources:seed",
    "field-sources:seed:remote": "dotenv -e .env.local -- pnpm run field-sources:seed",
    "release:health": "node --import tsx scripts/release-health.ts",
    "ship": "node --import tsx scripts/ship.ts"
  },
  "dependencies": {
    "@base-ui/react": "^1.3.0",
    "@dnd-kit/core": "^6.3.1",
    "@dnd-kit/modifiers": "^9.0.0",
    "@dnd-kit/sortable": "^10.0.0",
    "@dnd-kit/utilities": "^3.2.2",
    "@supabase/ssr": "^0.10.2",
    "@supabase/supabase-js": "^2.103.0",
    "@tanstack/react-table": "^8.21.3",
    "@tanstack/react-virtual": "^3.13.23",
    "@vercel/analytics": "^2.0.1",
    "@vercel/blob": "^2.3.3",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "decimal.js": "^10.6.0",
    "drizzle-orm": "^0.45.2",
    "lucide-react": "^1.8.0",
    "next": "16.2.3",
    "papaparse": "^5.5.3",
    "postgres": "^3.4.9",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "shadcn": "^4.2.0",
    "sonner": "^2.0.7",
    "tailwind-merge": "^3.5.0",
    "tw-animate-css": "^1.4.0",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@playwright/test": "^1.59.1",
    "@tailwindcss/postcss": "^4",
    "@testing-library/dom": "^10.4.1",
    "@testing-library/react": "^16.3.2",
    "@types/node": "^20",
    "@types/papaparse": "^5.5.2",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "@vitest/coverage-v8": "^4.1.4",
    "dotenv-cli": "^11.0.0",
    "drizzle-kit": "^0.31.10",
    "eslint": "^9",
    "eslint-config-next": "16.2.3",
    "jsdom": "^29.0.2",
    "tailwindcss": "^4",
    "tsx": "^4.21.0",
    "typescript": "^5",
    "vitest": "^4.1.4"
  }
}
